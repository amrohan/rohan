---
import Timeline from "../components/Timeline.astro";
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";

const workExperience = await getCollection("work");
---

<Layout title="Work" description="A work experience regarding the job">
  <section class="container max-w-5xl mx-auto p-4">
    <h2 class="text-lg font-bold text-text/80 mt-6">Work Experience</h2>
    {workExperience.map((work) => <Timeline {...work.data} />)}
  </section>
</Layout>
