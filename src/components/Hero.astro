---
import { Image } from "astro:assets";
import HeroImage from "../assets/hero.svg";
---

<section class="container max-w-4xl mx-auto p-4">
  <div
    class="md:flex md:flex-none md:justify-between md:items-center h-[35rem] gap-2"
  >
    <Image
      src={HeroImage}
      alt="hero image"
      width={384}
      height={384}
      class="size-96 w-full mb-2 md:mb-0"
    />
    <div class="flex flex-col justify-start items-start gap-4 mt-4">
      <p class="text-text">
        My name is Rohan Salunkhe. I am a full-stack developer and passionate
        about building various software applications.
      </p>
      <a
        href="https://docs.google.com/document/d/1SYPGkTmxTxBqdw1lucrSAUDtsRgHv-VQX0jzZIjD2U0/edit?usp=sharing"
        target="_blank"
        class="flex justify-center items-center gap-1 bg-primary rounded-md py-1.5 px-4"
      >
        Resume
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-idth="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
  {/* Work Exp */}
  <div class="mt-10">
    <h2 class="text-2xl font-bold text-text">Work Experience</h2>
    <div class="mt-4 text-text/90">
      <p>
        I have worked on various projects and have experience in various
        technologies.
      </p>
    </div>
    <!-- <Suspense fallback={<TimelineSkeleton />}>
          <TimeLine />
        </Suspense> -->
  </div>
</section>
