---
import Navbar from "../components/Navbar.astro";

const {
  title = "Rohan Salunkhe",
  description = "Welcome to the personal website of Rohan Salunkhe, a passionate Full-Stack Developer. Explore my projects, development expertise, and innovative solutions built using modern technologies.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-background">
    <Navbar />
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
